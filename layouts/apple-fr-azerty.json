{
  "id": "apple-fr-azerty",
  "name": {
    "en": "Apple French (AZERTY)",
    "fr": "Apple Francais (AZERTY)"
  },
  "locale": "fr-FR",
  "localeId": "0000040c",
  "dllName": "kbdaplfr",
  "description": {
    "en": "French AZERTY layout matching Apple Magic Keyboard keycaps. Fixes the mismatch between Apple's key labels and Windows' default French layout.",
    "fr": "Disposition AZERTY francaise correspondant aux inscriptions du Magic Keyboard Apple. Corrige le decalage entre les symboles imprimes sur les touches Apple et la disposition francaise par defaut de Windows."
  },
  "detectionKeys": [
    {
      "eventCode": "Backquote",
      "prompt": {
        "en": "Press the key to the LEFT of the 1 key (top-left area)",
        "fr": "Appuyez sur la touche a GAUCHE du 1 (en haut a gauche)"
      },
      "expectedBase": "@"
    },
    {
      "eventCode": "Digit8",
      "prompt": {
        "en": "Press the key between 7 and 9 on the number row",
        "fr": "Appuyez sur la touche entre 7 et 9 sur la rangee des chiffres"
      },
      "expectedBase": "!"
    },
    {
      "eventCode": "Digit6",
      "prompt": {
        "en": "Press the key between 5 and 7 on the number row",
        "fr": "Appuyez sur la touche entre 5 et 7 sur la rangee des chiffres"
      },
      "expectedBase": "\u00a7"
    },
    {
      "eventCode": "Minus",
      "prompt": {
        "en": "Press the key to the RIGHT of the 0 key, two keys before Backspace",
        "fr": "Appuyez sur la touche a DROITE du 0, deux touches avant Retour"
      },
      "expectedBase": ")"
    }
  ],
