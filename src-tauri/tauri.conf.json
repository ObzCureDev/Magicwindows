{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MagicWindows",
  "version": "0.1.0",
  "identifier": "dev.obzcure.magicwindows",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MagicWindows",
        "width": 900,
        "height": 650,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ObzCureDev/MagicWindows/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../layouts/*.json": "layouts/",
      "kbd_dlls/*.dll": "kbd_dlls/"
    }
  }
}
